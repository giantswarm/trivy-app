{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "ciliumNetworkPolicy": {
            "properties": {
                "enabled": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "kyvernoPolicyExceptions": {
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "namespace": {
                    "type": "string"
                }
            },
            "type": "object"
        },
        "networkPolicy": {
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "ingress": {
                    "properties": {
                        "namespaceSelector": {
                            "type": "object"
                        },
                        "podSelector": {
                            "type": "object"
                        }
                    },
                    "type": "object"
                }
            },
            "type": "object"
        },
        "trivy": {
            "properties": {
